    "**The data doesn't have duplicated values.**"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Handling outliers:"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Detecting Outliers:<br>\n",
    "Q1 = data.quantile(0.25)<br>\n",
    "Q3 = data.quantile(0.75)<br>\n",
    "IQR = Q3 - Q1<br>\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "metadata": {},
   "outputs": [],
   "source": [
    "col=['Year','Mileage','Engine','Power','Kilometers_Driven','Price']\n",
    "for i in col:\n",
    "    Q1 = data['{}'.format(i)].quantile(0.25)\n",
    "    Q3 = data['{}'.format(i)].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    m1=Q1 - (1.5 * IQR)\n",
    "    m2=Q3 + (1.5 * IQR)\n",
    "    k2=data.loc[data['{}'.format(i)]>=m2, '{}'.format(i)].median()\n",
    "    k1=data.loc[data['{}'.format(i)]<=m1, '{}'.format(i)].median()\n",
    "    data.loc[data['{}'.format(i)]>=m2, '{}'.format(i)]=k2\n",
    "    data.loc[data['{}'.format(i)]<=m1, '{}'.format(i)]=k1"
   ]
  },
